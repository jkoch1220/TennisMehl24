# Tesla Inventory Query (passt zur URL von tesla.com/de_DE/inventory/new/...)
TESLA_MODEL=my
TESLA_CONDITION=new
TESLA_MARKET=DE
TESLA_LANGUAGE=de
TESLA_ZIP=60313
TESLA_ARRANGEBY=Price
TESLA_ORDER=asc
TESLA_PAYMENT_TYPE=cash

# Poll-Intervall in Minuten
POLL_INTERVAL_MINUTES=5

# Pfad für persistente Daten (auf VPS z.B. /var/lib/tesla-bot)
DATA_DIR=./data

# === Discord (optional) ===
# Webhook URL aus Discord Server-Einstellungen > Integrationen > Webhooks
DISCORD_WEBHOOK_URL=

# === Telegram (optional) ===
# Bot-Token von @BotFather und Chat-ID (an Bot Nachricht schicken, dann https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
