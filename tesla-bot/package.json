{
  "name": "tesla-inventory-bot",
  "version": "1.0.0",
  "description": "Crawls Tesla inventory and sends notifications on new vehicles via Discord and Telegram",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "once": "tsx src/index.ts --once"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
